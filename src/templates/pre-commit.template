#!/bin/bash

# Pre-commit hook to validate task structure

# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}Running task template validation...${NC}"

# Check if any task files are being committed (exclude deleted files and completed tasks)
# Only validate files in backlog/tasks/ directory, not in completed/ or archive/
TASK_FILES=$(git diff --cached --name-only --diff-filter=d | grep "^backlog/tasks/.*\.md$" || true)

if [ -n "$TASK_FILES" ]; then
    echo "${YELLOW}Found active task files in commit, validating template compliance...${NC}"
    echo "${YELLOW}Note: Completed tasks in backlog/completed/ are not validated${NC}"

    VALIDATION_FAILED=false

    # Process each file (handles spaces in filenames)
    while IFS= read -r TASK_FILE; do
        if [ -n "$TASK_FILE" ]; then
            # Double-check file exists (in case of rename/move operations)
            if [ -f "$TASK_FILE" ]; then
                node scripts/validate-task.js "$TASK_FILE"
                if [ $? -ne 0 ]; then
                    echo ""
                    echo "${RED}❌ COMMIT BLOCKED: $TASK_FILE does not follow the required template${NC}"
                    echo "${YELLOW}Please ensure all tasks include:${NC}"
                    echo "  • All mandatory acceptance criteria from the template"
                    echo "  • Required sections (Description, Implementation Plan, Git Workflow, etc.)"
                    echo "  • Proper priority and labels"
                    echo ""
                    echo "${YELLOW}Run 'node scripts/validate-task.js \"$TASK_FILE\"' to see specific issues${NC}"
                    VALIDATION_FAILED=true
                fi
            else
                echo "${YELLOW}Skipping validation for deleted/moved file: $TASK_FILE${NC}"
            fi
        fi
    done <<< "$TASK_FILES"

    if [ "$VALIDATION_FAILED" = true ]; then
        exit 1
    fi

    echo "${GREEN}✅ Task validation passed${NC}"
fi

# Update project structure in .claude/project-structure.md
# This happens for ALL branches (main and worktrees)
# Check if there are any added or deleted files
CHANGED_FILES=$(git diff --cached --name-status | grep -E '^[AD]' || true)

if [ -n "$CHANGED_FILES" ]; then
    echo "${YELLOW}Updating project structure in .claude/project-structure.md...${NC}"

    # Run the update script if it exists
    if [ -f "scripts/update-project-structure.js" ]; then
        node scripts/update-project-structure.js

        # Stage the updated project-structure.md if it was modified
        if git diff --name-only | grep -q ".claude/project-structure.md"; then
            git add .claude/project-structure.md
            echo "${GREEN}✅ Project structure updated and staged${NC}"
        fi
    fi
fi

# Continue with other pre-commit checks if needed
exit 0