{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "v0-planner-output",
  "title": "V0 Planner Agent Output Schema",
  "description": "JSON output schema for v0-planner agent. Extends agent-output-base.schema.json using allOf composition.",
  "allOf": [
    { "$ref": "../templates/.claude/schemas/agent-output-base.schema.json" }
  ],
  "type": "object",
  "properties": {
    "agent_type": {
      "type": "string",
      "description": "Agent category for UI generation",
      "enum": ["ui-generation"]
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "partial", "blocked", "skipped"],
      "default": "success"
    },
    "nextAction": {
      "type": "object",
      "description": "Orchestration instructions for what should happen next",
      "properties": {
        "type": { "type": "string", "enum": ["spawn_agent", "create_task", "update_task", "complete_task", "none", "user_input", "hook_action", "cli_command"] },
        "agent_type": { "type": "string", "enum": ["task-management", "implementation", "review", "documentation", "ui-generation", "architecture", "refactor", "debug", "explore"] },
        "agent_name": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"], "default": "medium" },
        "payload": {
          "type": "object",
          "description": "Data payload for the next action",
          "properties": {
            "component_specs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "component_spec": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string", "minLength": 3, "maxLength": 50 },
                      "description": { "type": "string", "minLength": 10 },
                      "requirements": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                      "styling_notes": { "type": "string" },
                      "dependencies": { "type": "array", "items": { "type": "string" }, "default": [] }
                    },
                    "required": ["name", "description", "requirements", "styling_notes"]
                  }
                }
              }
            },
            "integration_task": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "acceptance_criteria": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "results": {
      "type": "object",
      "description": "V0 planner specific results - UI components to generate",
      "properties": {
        "agent_type": {
          "type": "string",
          "const": "ui-generation"
        },
        "components": {
          "type": "array",
          "description": "UI components to generate with v0-ui-generator",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "minLength": 3, "maxLength": 50 },
              "description": { "type": "string", "minLength": 10 },
              "requirements": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "styling_notes": { "type": "string" },
              "dependencies": { "type": "array", "items": { "type": "string" }, "default": [] }
            },
            "required": ["name", "description", "requirements", "styling_notes"]
          }
        },
        "integration_task": {
          "type": "object",
          "description": "Specification for integration task combining all components",
          "properties": {
            "title": { "type": "string" },
            "acceptance_criteria": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["title", "acceptance_criteria"]
        }
      },
      "required": ["agent_type", "components", "integration_task"]
    }
  }
}
