{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["permissions", "hooks"],
  "properties": {
    "permissions": {
      "type": "object",
      "required": ["allow", "deny", "ask"],
      "properties": {
        "allow": {
          "type": "array",
          "items": { "type": "string" }
        },
        "deny": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ask": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["matcher", "hooks"],
            "properties": {
              "matcher": { "type": "string" },
              "hooks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "command"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["command"]
                    },
                    "command": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "outputStyle": {
      "type": "string",
      "enum": ["default", "minimal", "verbose"]
    },
    "thinkingMode": {
      "type": "string",
      "enum": ["enabled", "disabled"]
    }
  },
  "additionalProperties": false
}
